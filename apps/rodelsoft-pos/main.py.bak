        }}

        .products-grid {{
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 1rem;
            max-height: 60vh;
            overflow-y: auto;
        }}

        .product-card {{
            background: white;
            border: 1px solid var(--border);
